<view class="detail-page-ios">
  <!-- iOS导航栏 -->
  <view class="ios-nav-bar">
    <view class="ios-nav-back" bindtap="onGoBack">
      <van-icon name="arrow-left" size="20px" color="#007AFF" />
    </view>
    <view class="ios-nav-title">图片详情</view>
  </view>

  <!-- 加载状态 -->
  <view class="ios-loading" wx:if="{{loading}}">
    <van-loading size="24px" color="#007AFF" />
    <text class="ios-loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="ios-error" wx:elif="{{error}}">
    <van-icon name="warning-o" size="48px" color="#C6C6C8" />
    <text class="ios-error-text">{{error}}</text>
    <view class="ios-btn ios-btn-primary" bindtap="onGoBack" style="margin-top: 20px;">
      返回图库
    </view>
  </view>

  <!-- 图片详情内容 -->
  <scroll-view class="ios-detail-content" scroll-y wx:elif="{{picture}}">
    <!-- 图片展示 -->
    <view class="ios-image-section">
      <image
        class="ios-detail-image"
        src="{{picture.url}}"
        mode="widthFix"
        lazy-load
        bindtap="onPreviewImage"
        show-menu-by-longpress
      />
    </view>

    <!-- 图片信息卡片 -->
    <view class="ios-detail-card">
      <!-- 标题 -->
      <view class="ios-detail-title">{{picture.name || '未命名'}}</view>

      <!-- 统计信息 -->
      <view class="ios-detail-stats">
        <view class="ios-stat">
          <van-icon name="eye-o" size="18px" color="#8E8E93" />
          <text class="ios-stat-num">{{picture.viewCount || 0}}</text>
          <text class="ios-stat-label">浏览</text>
        </view>
        <view class="ios-stat-divider"></view>
        <view class="ios-stat {{isLiked ? 'liked' : ''}}" bindtap="onToggleLike">
          <van-icon name="{{isLiked ? 'like' : 'like-o'}}" size="18px" color="{{isLiked ? '#FF3B30' : '#8E8E93'}}" />
          <text class="ios-stat-num">{{likeCount}}</text>
          <text class="ios-stat-label">点赞</text>
        </view>
      </view>

      <!-- 标签 -->
      <view class="ios-detail-tags" wx:if="{{picture.tags && picture.tags.length > 0}}">
        <view class="ios-tag-small" wx:for="{{picture.tags}}" wx:key="index">{{item}}</view>
      </view>

      <!-- 简介 -->
      <view class="ios-detail-desc" wx:if="{{picture.introduction}}">
        <view class="ios-desc-label">简介</view>
        <text class="ios-desc-text">{{picture.introduction}}</text>
      </view>
    </view>

    <!-- 详细信息 -->
    <view class="ios-info-group">
      <view class="ios-info-item">
        <text class="ios-info-label">上传时间</text>
        <text class="ios-info-value">{{picture.createTime}}</text>
      </view>
      <view class="ios-info-item">
        <text class="ios-info-label">上传者</text>
        <text class="ios-info-value">{{picture.userVO.userName || '未知'}}</text>
      </view>
      <view class="ios-info-item">
        <text class="ios-info-label">分类</text>
        <text class="ios-info-value">{{picture.categoryVO.name || '未分类'}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="ios-detail-actions">
      <view class="ios-btn ios-btn-primary ios-action-btn" bindtap="onToggleLike">
        <van-icon name="{{isLiked ? 'like' : 'like-o'}}" size="18px" color="#FFFFFF" />
        <text>{{isLiked ? '已点赞' : '点赞'}}</text>
      </view>
      <view class="ios-btn ios-btn-secondary ios-action-btn" bindtap="onDownloadImage">
        <van-icon name="down" size="18px" color="#007AFF" />
        <text>保存图片</text>
      </view>
    </view>

    <!-- 更多推荐 -->
    <view class="ios-recommend">
      <view class="ios-recommend-header">
        <text class="ios-recommend-title">更多图片</text>
      </view>
      <view class="ios-empty-state">
        <van-icon name="photo-o" size="32px" color="#C6C6C8" />
        <text class="ios-empty-text">暂无推荐</text>
      </view>
    </view>
  </scroll-view>
</view>