/* 注册页面样式 */
.register-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.background-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.circle-1 {
  width: 200px;
  height: 200px;
  top: -50px;
  right: -50px;
}

.circle-2 {
  width: 150px;
  height: 150px;
  bottom: 100px;
  left: -30px;
}

.circle-3 {
  width: 100px;
  height: 100px;
  top: 200px;
  right: 50px;
}

.page-content {
  height: 100vh;
  padding: 20px;
  box-sizing: border-box;
}

/* 返回按钮 */
.back-button {
  position: absolute;
  top: 20px;
  left: 20px;
  z-index: 100;
  padding: 12px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
}

.back-button:active {
  background: rgba(0, 0, 0, 0.3);
}

/* Logo区域 */
.logo-section {
  text-align: center;
  padding: 60px 0 40px;
}

.logo-placeholder {
  width: 80px;
  height: 80px;
  margin: 0 auto 20px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}

.app-name {
  font-size: 28px;
  font-weight: 600;
  color: #ffffff;
  margin: 20px 0 8px;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
}

.app-slogan {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  padding: 0 16px;
}

.van-cell-group--inset {
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
}

/* 错误消息 */
.error-message {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 16px;
  background: #fff2f0;
  font-size: 12px;
  color: #ff4d4f;
}

/* 按钮区域 */
.button-section {
  padding: 0 16px 20px;
}

.login-section {
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 14px;
}

.login-link {
  color: #ffffff;
  font-weight: 500;
  margin-left: 8px;
}

.login-link:active {
  opacity: 0.8;
}

/* 用户协议 */
.agreement-section {
  padding: 20px 16px 0;
  text-align: center;
}

.agreement-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

.agreement-link {
  color: #ffffff;
  text-decoration: underline;
}

.agreement-link:active {
  opacity: 0.8;
}

/* 响应式设计 */
@media (min-width: 768px) {
  .page-content {
    max-width: 480px;
    margin: 0 auto;
    padding: 40px;
  }
  
  .logo-section {
    padding: 40px 0 30px;
  }
  
  .app-name {
    font-size: 32px;
  }
  
  .form-section {
    padding: 0;
  }
  
  .button-section,
  .agreement-section {
    padding: 0;
  }
  
  .back-button {
    top: 40px;
    left: 40px;
  }
}

/* 横屏适配 */
@media (orientation: landscape) and (min-width: 768px) {
  .logo-section {
    padding: 20px 0;
  }
  
  .page-content {
    display: flex;
    align-items: center;
  }
  
  .form-section {
    flex: 1;
    max-width: 400px;
  }
  
  .back-button {
    position: static;
    margin-bottom: 20px;
    display: inline-block;
  }
}