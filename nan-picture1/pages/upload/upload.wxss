/* iOS风格上传页面 */

.upload-page-ios {
  background-color: #F2F2F7;
  min-height: 100vh;
}

/* 导航栏 */
.ios-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 96px;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 0.5px solid #C6C6C8;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 12px;
  padding-top: env(safe-area-inset-top);
}

.ios-nav-back {
  position: absolute;
  left: 8px;
  bottom: 8px;
  padding: 8px;
}

.ios-nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #1C1C1E;
}

/* 页面内容 */
.ios-page-content {
  padding: 108px 16px 120px;
  height: 100vh;
  box-sizing: border-box;
}

/* 区块 */
.ios-section {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.ios-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.ios-section-title {
  font-size: 17px;
  font-weight: 600;
  color: #1C1C1E;
}

.ios-section-desc {
  font-size: 13px;
  color: #8E8E93;
}

/* 图片网格 */
.ios-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.ios-image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12px;
  overflow: hidden;
  background: #F2F2F7;
}

.ios-preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 状态覆盖层 */
.ios-status-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ios-status-overlay.uploading {
  background: rgba(0, 122, 255, 0.85);
}

.ios-status-overlay.success {
  background: rgba(52, 199, 89, 0.85);
}

.ios-status-overlay.fail {
  background: rgba(255, 59, 48, 0.85);
}

/* 删除按钮 */
.ios-delete-btn {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 24px;
  height: 24px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 添加按钮 */
.ios-add-btn {
  aspect-ratio: 1;
  border: 2px dashed #C6C6C8;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  transition: all 0.2s ease;
}

.ios-add-btn:active {
  border-color: #007AFF;
  background: rgba(0, 122, 255, 0.05);
}

.ios-add-text {
  font-size: 13px;
  color: #8E8E93;
  margin-top: 8px;
}

/* 输入框 */
.ios-field-group {
  margin-bottom: 16px;
}

.ios-field {
  display: flex;
  align-items: center;
  background: #F2F2F7;
  border-radius: 12px;
  padding: 0 16px;
  min-height: 48px;
}

.ios-field-textarea {
  align-items: flex-start;
  padding-top: 12px;
}

.ios-field-label {
  font-size: 15px;
  font-weight: 500;
  color: #1C1C1E;
  width: 48px;
  flex-shrink: 0;
}

.ios-field-input {
  flex: 1;
  font-size: 17px;
  color: #1C1C1E;
  background: transparent;
  min-height: 48px;
}

.ios-field-placeholder {
  color: #C6C6C8;
}

.ios-field-required {
  color: #FF3B30;
  font-size: 17px;
  margin-left: 4px;
}

.ios-field-error {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 16px 0;
  font-size: 13px;
  color: #FF3B30;
}

/* 标签区域 */
.ios-tags-section {
  margin-top: 16px;
}

.ios-section-label {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 15px;
  color: #1C1C1E;
  margin-bottom: 12px;
}

.ios-tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.ios-tag {
  padding: 8px 14px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 500;
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
  transition: all 0.2s ease;
}

.ios-tag-active {
  background: #007AFF;
  color: #FFFFFF;
}

/* 上传按钮 */
.ios-upload-actions {
  margin-top: 24px;
}

.ios-upload-btn {
  width: 100%;
  min-height: 50px;
}

.ios-upload-btn.disabled {
  opacity: 0.5;
}

/* 选择器头部 */
.ios-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 0.5px solid #C6C6C8;
}

.ios-picker-cancel {
  font-size: 17px;
  color: #8E8E93;
}

.ios-picker-title {
  font-size: 17px;
  font-weight: 600;
  color: #1C1C1E;
}

.ios-picker-confirm {
  font-size: 17px;
  color: #007AFF;
  font-weight: 500;
}