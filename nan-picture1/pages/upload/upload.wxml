<view class="upload-page-ios">
  <!-- iOS导航栏 -->
  <view class="ios-nav-bar">
    <view class="ios-nav-back" bindtap="onGoBack">
      <van-icon name="arrow-left" size="20px" color="#007AFF" />
    </view>
    <view class="ios-nav-title">上传图片</view>
  </view>

  <scroll-view class="ios-page-content" scroll-y>
    <!-- 图片选择区域 -->
    <view class="ios-section">
      <view class="ios-section-header">
        <text class="ios-section-title">选择图片</text>
        <text class="ios-section-desc">最多可选{{maxFiles}}张</text>
      </view>

      <view class="ios-image-grid">
        <!-- 已选图片 -->
        <view class="ios-image-item" wx:for="{{fileList}}" wx:key="url">
          <image src="{{item.url}}" mode="aspectFill" class="ios-preview-img" bindtap="onPreviewImage" data-index="{{index}}" />

          <!-- 状态覆盖层 -->
          <view class="ios-status-overlay {{item.status}}" wx:if="{{item.status !== 'ready'}}">
            <van-loading wx:if="{{item.status === 'uploading'}}" size="24px" color="#FFFFFF" />
            <van-icon wx:elif="{{item.status === 'success'}}" name="success" size="24px" color="#34C759" />
            <van-icon wx:elif="{{item.status === 'fail'}}" name="cross" size="24px" color="#FF3B30" />
          </view>

          <!-- 删除按钮 -->
          <view class="ios-delete-btn" wx:if="{{item.status === 'ready'}}" catchtap="onRemoveImage" data-index="{{index}}">
            <van-icon name="cross" size="14px" color="#FFFFFF" />
          </view>
        </view>

        <!-- 添加按钮 -->
        <view class="ios-add-btn" wx:if="{{fileList.length < maxFiles}}" bindtap="onSelectImages">
          <van-icon name="plus" size="32px" color="#C6C6C8" />
          <text class="ios-add-text">添加图片</text>
        </view>
      </view>

      <view class="ios-field-error" wx:if="{{errors.files}}">
        <van-icon name="warning-o" size="14px" color="#FF3B30" />
        <text>{{errors.files}}</text>
      </view>
    </view>

    <!-- 图片信息 -->
    <view class="ios-section">
      <view class="ios-section-header">
        <text class="ios-section-title">图片信息</text>
      </view>

      <!-- 标题 -->
      <view class="ios-field-group">
        <view class="ios-field">
          <text class="ios-field-label">标题</text>
          <input
            class="ios-field-input"
            placeholder="请输入图片标题"
            placeholder-class="ios-field-placeholder"
            value="{{pictureInfo.title}}"
            data-field="title"
            bindinput="onInputChange"
            maxlength="50"
          />
          <text class="ios-field-required">*</text>
        </view>
        <view class="ios-field-error" wx:if="{{errors.title}}">
          <van-icon name="warning-o" size="14px" color="#FF3B30" />
          <text>{{errors.title}}</text>
        </view>
      </view>

      <!-- 描述 -->
      <view class="ios-field-group">
        <view class="ios-field ios-field-textarea">
          <text class="ios-field-label">描述</text>
          <textarea
            class="ios-field-input"
            placeholder="请输入图片描述（可选）"
            placeholder-class="ios-field-placeholder"
            value="{{pictureInfo.description}}"
            data-field="description"
            bindinput="onInputChange"
            maxlength="200"
            auto-height
          />
        </view>
      </view>

      <!-- 标签 -->
      <view class="ios-tags-section">
        <view class="ios-section-label">
          <text>标签</text>
          <text class="ios-field-required">*</text>
        </view>
        <view class="ios-tags-grid">
          <view
            wx:for="{{tags}}"
            wx:key="index"
            class="ios-tag {{pictureInfo.tags.indexOf(item) > -1 ? 'ios-tag-active' : ''}}"
            data-tag="{{item}}"
            bindtap="onTagSelect"
          >
            {{item}}
          </view>
        </view>
        <view class="ios-field-error" wx:if="{{errors.tags}}">
          <van-icon name="warning-o" size="14px" color="#FF3B30" />
          <text>{{errors.tags}}</text>
        </view>
      </view>
    </view>

    <!-- 上传按钮 -->
    <view class="ios-upload-actions">
      <view class="ios-btn ios-btn-primary ios-upload-btn {{uploading || fileList.length === 0 ? 'disabled' : ''}}" bindtap="onStartUpload">
        <van-loading wx:if="{{uploading}}" size="20px" color="#FFFFFF" />
        <text wx:else>{{uploading ? '上传中...' : '开始上传'}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部导航 -->
  <bottom-tab active="{{activeTab}}" />

  <!-- 分类选择器 -->
  <van-popup
    show="{{showCategoryPicker}}"
    position="bottom"
    round
    bind:close="onCategoryPickerClose"
  >
    <view class="ios-picker-header">
      <text class="ios-picker-cancel" bindtap="onCategoryPickerClose">取消</text>
      <text class="ios-picker-title">选择分类</text>
      <text class="ios-picker-confirm" bindtap="onCategoryConfirm">确定</text>
    </view>
    <van-picker
      show-toolbar="{{false}}"
      columns="{{categories}}"
      bind:confirm="onCategoryConfirm"
    />
  </van-popup>
</view>