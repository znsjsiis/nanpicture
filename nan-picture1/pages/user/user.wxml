<view class="user-page-ios">
  <!-- iOS导航栏 -->
  <view class="ios-nav-bar">
    <view class="ios-nav-title-large">我的</view>
  </view>

  <!-- 用户卡片 -->
  <view class="ios-user-card">
    <view class="ios-user-card-bg"></view>
    <view class="ios-user-card-content">
      <!-- 头像 -->
      <view class="ios-user-avatar">
        <van-image
          src="{{userInfo.avatarUrl || 'https://img.yzcdn.cn/vant/cat.jpeg'}}"
          width="64px"
          height="64px"
          round
          fit="cover"
        />
      </view>

      <!-- 用户信息 -->
      <view class="ios-user-info">
        <view class="ios-user-name">{{userInfo.userName || userInfo.userAccount || '未知用户'}}</view>
        <view class="ios-user-id">ID: {{userInfo.id}}</view>
      </view>

      <!-- 会员标签 -->
      <view class="ios-user-badge">
        <view class="ios-badge {{userInfo.userRole === 'admin' ? 'admin' : ''}}">
          {{userInfo.userRole === 'admin' ? '管理员' : '普通用户'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="ios-stats-card">
    <view class="ios-stat-item">
      <view class="ios-stat-num">{{statistics.uploadCount}}</view>
      <view class="ios-stat-label">上传</view>
    </view>
    <view class="ios-stat-divider"></view>
    <view class="ios-stat-item">
      <view class="ios-stat-num">{{statistics.likeCount}}</view>
      <view class="ios-stat-label">获赞</view>
    </view>
    <view class="ios-stat-divider"></view>
    <view class="ios-stat-item">
      <view class="ios-stat-num">{{statistics.followerCount}}</view>
      <view class="ios-stat-label">粉丝</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="ios-menu-group">
    <view class="ios-group-header">功能</view>
    <view class="ios-group-content">
      <view class="ios-list-item" bindtap="onViewMyUploads">
        <view class="ios-list-item-icon" style="background: #007AFF;">
          <van-icon name="photo-o" size="16px" color="#FFFFFF" />
        </view>
        <view class="ios-list-item-content">
          <text class="ios-list-item-title">我的上传</text>
        </view>
        <van-icon name="arrow" size="16px" class="ios-list-item-arrow" color="#C6C6C8" />
      </view>

      <view class="ios-list-item" bindtap="onViewFavorites">
        <view class="ios-list-item-icon" style="background: #FF9500;">
          <van-icon name="star-o" size="16px" color="#FFFFFF" />
        </view>
        <view class="ios-list-item-content">
          <text class="ios-list-item-title">我的收藏</text>
        </view>
        <van-icon name="arrow" size="16px" class="ios-list-item-arrow" color="#C6C6C8" />
      </view>

      <view class="ios-list-item" bindtap="onSettings">
        <view class="ios-list-item-icon" style="background: #8E8E93;">
          <van-icon name="setting-o" size="16px" color="#FFFFFF" />
        </view>
        <view class="ios-list-item-content">
          <text class="ios-list-item-title">设置</text>
        </view>
        <van-icon name="arrow" size="16px" class="ios-list-item-arrow" color="#C6C6C8" />
      </view>

      <view class="ios-list-item" bindtap="onAbout">
        <view class="ios-list-item-icon" style="background: #34C759;">
          <van-icon name="info-o" size="16px" color="#FFFFFF" />
        </view>
        <view class="ios-list-item-content">
          <text class="ios-list-item-title">关于我们</text>
        </view>
        <van-icon name="arrow" size="16px" class="ios-list-item-arrow" color="#C6C6C8" />
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="ios-logout-section">
    <view class="ios-btn ios-btn-danger ios-btn-full" bindtap="onShowLogoutDialog">
      退出登录
    </view>
  </view>

  <!-- 底部导航 -->
  <bottom-tab active="{{activeTab}}" />

  <!-- 退出确认对话框 -->
  <van-dialog
    use-slot
    title="确认退出"
    show="{{showLogoutDialog}}"
    show-cancel-button
    confirm-button-color="#FF3B30"
    bind:confirm="onConfirmLogout"
    bind:cancel="onHideLogoutDialog"
  >
    <view class="ios-dialog-content">
      <van-icon name="warning-o" size="48px" color="#FF3B30" />
      <text class="ios-dialog-text">确定要退出登录吗？</text>
    </view>
  </van-dialog>
</view>