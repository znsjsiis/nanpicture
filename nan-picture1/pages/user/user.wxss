/* 用户中心页面样式 */
.user-page {
  background-color: #f5f5f5;
}

.page-content {
  height: calc(100vh - 44px - 50px - env(safe-area-inset-bottom));
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 20px;
  margin: 12px;
}

.user-avatar-section {
  margin-right: 16px;
}

.user-info-section {
  flex: 1;
}

.user-name {
  font-size: 20px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4px;
}

.user-id {
  font-size: 14px;
  color: #999999;
  margin-bottom: 8px;
}

.user-role {
  display: inline-block;
}

.edit-profile-btn {
  padding: 8px;
  border-radius: 50%;
  background: #f0f8ff;
  transition: all 0.2s ease;
}

.edit-profile-btn:active {
  background: #e6f4ff;
  transform: scale(0.95);
}

/* 统计信息 */
.statistics-section {
  display: flex;
  justify-content: space-around;
  text-align: center;
  padding: 20px;
  margin: 12px;
}

.statistic-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.statistic-number {
  font-size: 24px;
  font-weight: 600;
  color: #1677ff;
  margin-bottom: 4px;
}

.statistic-label {
  font-size: 14px;
  color: #666666;
}

/* 菜单区域 */
.menu-section {
  margin: 12px;
  padding: 0;
  overflow: hidden;
}

.menu-section .van-cell {
  padding: 16px 20px;
}

.menu-section .van-cell:not(:last-child) {
  border-bottom: 1px solid #f0f0f0;
}

/* 退出登录区域 */
.logout-section {
  padding: 16px;
  margin: 12px;
}

/* 对话框样式 */
.dialog-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
}

.dialog-text {
  margin-top: 16px;
  font-size: 16px;
  color: #333333;
  text-align: center;
}

/* 响应式设计 */
@media (min-width: 768px) {
  .user-card {
    padding: 24px;
    margin: 16px;
  }
  
  .user-name {
    font-size: 24px;
  }
  
  .statistic-number {
    font-size: 28px;
  }
  
  .statistics-section {
    padding: 24px;
  }
  
  .menu-section {
    margin: 16px;
  }
  
  .logout-section {
    padding: 20px;
    margin: 16px;
  }
}

/* 横屏适配 */
@media (orientation: landscape) and (min-width: 768px) {
  .page-content {
    height: calc(100vh - 44px - 60px - env(safe-area-inset-bottom));
  }
  
  .user-card {
    padding: 28px;
  }
  
  .statistics-section {
    padding: 28px;
  }
}