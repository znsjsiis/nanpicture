const request = require('../../utils/request.js');

Page({
  data: {
    pictures: [], // еӣҫзүҮеҲ—иЎЁ
    loading: false, // еҠ иҪҪзҠ¶жҖ?
    hasMore: true, // жҳҜеҗҰиҝҳжңүжӣҙеӨҡж•°жҚ®
    currentPage: 1, // еҪ“еүҚйЎөз Ғ
    pageSize: 20, // жҜҸйЎөж•°йҮҸ
    activeTab: 1, // еә•йғЁеҜјиҲӘйҖүдёӯйЎ?
    
    // зҖ‘еёғжөҒеёғеұҖзӣёе…і
    columns: 2, // еҲ—ж•°
    columnHeight: [0, 0], // жҜҸеҲ—зҡ„й«ҳеә?
    columnItems: [[], []], // жҜҸеҲ—зҡ„еӣҫзүҮж•°жҚ?
    
    // жҗңзҙўе’ҢзӯӣйҖ?
    searchKeyword: '',
    selectedTag: '',
    tags: ['е…ЁйғЁ', 'зғӯй—Ё', 'з”ҹжҙ»', 'й«ҳжё…', 'жёёжҲҸ', 'еҪұи§Ҷ', 'жұҪиҪҰ', 'иҝҗеҠЁ', 'з§‘жҠҖ']
  },

  onLoad() {
    console.log('еӣҫеә“йЎөйқўеҠ иҪҪ');
    // еҗҢж—¶еҠ иҪҪеӣҫзүҮе’Ңж Үзӯ?
    Promise.all([
      this.loadPictures(),
      this.loadTags()
    ]).then(() => {
      console.log('еҲқе§Ӣж•°жҚ®еҠ иҪҪе®ҢжҲҗ');
    }).catch(error => {
      console.error('еҲқе§Ӣж•°жҚ®еҠ иҪҪеӨұиҙҘ:', error);
    });
  },
  
  onShow() {
    console.log('еӣҫеә“йЎөйқўжҳҫзӨә');
    // йЎөйқўжҳҫзӨәж—¶еҲ·ж–°ж•°жҚ?
    this.refreshData();
    // зЎ®дҝқж ҮзӯҫйҮҚж–°еҠ иҪҪ
    this.loadTags();
  },

  /**
   * дёӢжӢүеҲ·ж–°
   */
  onPullDownRefresh() {
    this.refreshData().then(() => {
      wx.stopPullDownRefresh();
    });
  },

  /**
   * дёҠжӢүеҠ иҪҪжӣҙеӨҡ
   */
  onReachBottom() {
    if (this.data.hasMore && !this.data.loading) {
      this.loadMore();
    }
  },

  /**
   * еҲ·ж–°ж•°жҚ®
   */
  async refreshData() {
    console.log('ејҖе§ӢеҲ·ж–°ж•°жҚ?);
    this.setData({
      pictures: [],
      columnItems: [[], []],
      columnHeight: [0, 0],
      currentPage: 1,
      hasMore: true
    });
    
    // йҮҚж–°еҠ иҪҪжүҖжңүж•°жҚ?
    await Promise.all([
      this.loadPictures(),
      this.loadTags()
    ]);
    
    console.log('ж•°жҚ®еҲ·ж–°е®ҢжҲҗ');
  },

  /**
   * еҠ иҪҪеӣҫзүҮж•°жҚ®
   */
  async loadPictures() {
    if (this.data.loading || !this.data.hasMore) {
      return;
    }

    this.setData({ loading: true });

    try {
      const params = {
        current: this.data.currentPage,
        pageSize: this.data.pageSize,
        keyword: this.data.searchKeyword,
        tag: this.data.selectedTag === 'е…ЁйғЁ' ? '' : this.data.selectedTag
      };

      console.log('еҸ‘йҖҒиҜ·жұӮеҸӮж•?', params);
      
      const result = await request.post('/picture/list/page/vo', params);
      
      console.log('APIиҝ”еӣһз»“жһң:', result);
      
      // жЈҖжҹҘиҝ”еӣһж•°жҚ®з»“жһ?
      if (!result) {
        console.warn('APIиҝ”еӣһз©әз»“жһ?);
        this.setData({ hasMore: false });
        return;
      }
      
      if (result.records && result.records.length > 0) {
        console.log('жҺҘж”¶еҲ°зҡ„еӣҫзүҮж•°жҚ®:', result.records);
        
        // йӘҢиҜҒж•°жҚ®ж јејҸ
        result.records.forEach((pic, index) => {
          console.log(`еӣҫзүҮ${index}ж•°жҚ®з»“жһ„:`, {
            id: pic.id,
            url: pic.url,
            title: pic.title,
            name: pic.name,
            tags: pic.tags,
            tagsType: Array.isArray(pic.tags) ? 'array' : typeof pic.tags,
            tagsLength: pic.tags ? pic.tags.length : 0,
            hasUrl: !!pic.url,
            urlType: typeof pic.url
          });
                
          // иҜҰз»ҶжЈҖжҹҘж Үзӯҫж•°жҚ?
          if (pic.tags) {
            console.log(`еӣҫзүҮ${index}зҡ„ж ҮзӯҫиҜҰжғ?`, pic.tags);
            pic.tags.forEach((tag, tagIndex) => {
              console.log(`  ж Үзӯҫ${tagIndex}:`, tag, typeof tag);
            });
          }
        });
        
        // еӨ„зҗҶзҖ‘еёғжөҒеёғеұҖ
        this.processWaterfallLayout(result.records);
        
        this.setData({
          currentPage: this.data.currentPage + 1,
          hasMore: result.records.length >= this.data.pageSize
        });
      } else {
        console.log('жІЎжңүжӣҙеӨҡеӣҫзүҮж•°жҚ®');
        this.setData({ hasMore: false });
      }
    } catch (error) {
      console.error('еҠ иҪҪеӣҫзүҮеӨұиҙҘ:', error);
      wx.showToast({
        title: 'еҠ иҪҪеӨұиҙҘ',
        icon: 'none'
      });
    } finally {
      this.setData({ loading: false });
    }
  },

  /**
   * еӨ„зҗҶзҖ‘еёғжөҒеёғеұҖ
   */
  processWaterfallLayout(newPictures) {
    console.log('еӨ„зҗҶзҖ‘еёғжөҒеёғеұҖпјҢеӣҫзүҮж•°йҮ?', newPictures.length);
    const { columnItems, columnHeight } = this.data;
    const updatedColumnItems = [...columnItems];
    const updatedColumnHeight = [...columnHeight];

    newPictures.forEach((picture, index) => {
      console.log(`еӨ„зҗҶз¬?{index}еј еӣҫзү?`, picture);
      // жүҫеҲ°й«ҳеәҰжңҖзҹӯзҡ„еҲ?
      const minHeightIndex = updatedColumnHeight.indexOf(Math.min(...updatedColumnHeight));
      
      // ж·»еҠ еҲ°иҜҘеҲ?
      updatedColumnItems[minHeightIndex].push(picture);
      
      // жӣҙж–°иҜҘеҲ—й«ҳеәҰпјҲдј°з®—еӣҫзүҮй«ҳеәҰпјү
      const estimatedHeight = this.estimateImageHeight(picture);
      updatedColumnHeight[minHeightIndex] += estimatedHeight;
    });

    console.log('жӣҙж–°еҗҺзҡ„еҲ—ж•°жҚ?', updatedColumnItems);
    
    this.setData({
      columnItems: updatedColumnItems,
      columnHeight: updatedColumnHeight
    }, () => {
      console.log('setDataеӣһи°ғ - еҪ“еүҚж•°жҚ®:', this.data.columnItems);
      console.log('з¬¬дёҖеҲ—ж•°жҚ?', this.data.columnItems[0]);
      console.log('з¬¬дәҢеҲ—ж•°жҚ?', this.data.columnItems[1]);
    });
  },

  /**
   * дј°з®—еӣҫзүҮй«ҳеәҰ
   */
  estimateImageHeight(picture) {
    // еҒҮи®ҫеӣҫзүҮе®ҪеәҰдёәеұҸе№•е®ҪеәҰзҡ„дёҖеҚҠеҮҸеҺ»й—ҙи·?
    const screenWidth = wx.getSystemInfoSync().windowWidth;
    const imageWidth = (screenWidth - 24) / 2; // еҮҸеҺ»paddingе’Ңgap
    
    // еҰӮжһңжңүе®Ҫй«ҳдҝЎжҒҜпјҢжҢүжҜ”дҫӢи®Ўз®—пјӣеҗҰеҲҷдҪҝз”Ёй»ҳи®Өй«ҳеәҰ
    if (picture.width && picture.height) {
      return (imageWidth / picture.width) * picture.height + 60; // еҠ дёҠж–Үеӯ—жҸҸиҝ°й«ҳеәҰ
    }
    return 200; // й»ҳи®Өй«ҳеәҰ
  },

  /**
   * еҠ иҪҪжӣҙеӨҡ
   */
  loadMore() {
    this.loadPictures();
  },

  /**
   * еҠ иҪҪж ҮзӯҫеҲҶзұ»
   */
  async loadTags() {
    try {
      console.log('ејҖе§ӢеҠ иҪҪж ҮзӯҫеҲҶзұ?);
      const result = await request.get('/picture/tag_category');
      console.log('ж ҮзӯҫAPIиҝ”еӣһз»“жһң:', result);
      
      if (result && result.tagList) {
        const tags = ['е…ЁйғЁ', ...result.tagList];
        console.log('еӨ„зҗҶеҗҺзҡ„ж ҮзӯҫеҲ—иЎЁ:', tags);
        this.setData({ tags });
        console.log('и®ҫзҪ®еҗҺзҡ„data.tags:', this.data.tags);
      } else {
        console.warn('ж Үзӯҫж•°жҚ®ж јејҸдёҚжӯЈзЎ?', result);
      }
    } catch (error) {
      console.error('еҠ иҪҪж ҮзӯҫеӨұиҙҘ:', error);
    }
  },

  /**
   * ж ҮзӯҫйҖүжӢ©
   */
  onTagSelect(event) {
    const tag = event.currentTarget.dataset.tag;
    this.setData({
      selectedTag: tag,
      currentPage: 1,
      hasMore: true
    });
    this.refreshData();
  },

  /**
   * жҗңзҙў
   */
  onSearch() {
    this.setData({
      currentPage: 1,
      hasMore: true
    });
    this.refreshData();
  },

  /**
   * иҫ“е…ҘжЎҶеҸҳеҢ?
   */
  onSearchInput(event) {
    this.setData({
      searchKeyword: event.detail.value
    });
  },

  /**
   * жҹҘзңӢеӣҫзүҮиҜҰжғ…
   */
  onViewPicture(event) {
    const { index, columnIndex } = event.currentTarget.dataset;
    const picture = this.data.columnItems[columnIndex][index];
    
    wx.navigateTo({
      url: `/pages/picture-detail/picture-detail?id=${picture.id}`
    });
  },

  /**
   * йў„и§ҲеӣҫзүҮ
   */
  onPreviewImage(event) {
    const { index, columnIndex } = event.currentTarget.dataset;
    const picture = this.data.columnItems[columnIndex][index];
    
    wx.previewImage({
      urls: [picture.url],
      current: picture.url
    });
  }
});
