<view class="gallery-page-ios">
  <!-- iOS大标题导航栏 -->
  <view class="ios-nav-bar">
    <view class="ios-nav-title-large">图库</view>
  </view>

  <!-- 搜索栏 -->
  <view class="ios-search-bar">
    <van-icon name="search" size="16px" class="ios-search-icon" color="#8E8E93" />
    <input
      class="ios-search-input"
      placeholder="搜索图片"
      placeholder-class="ios-search-input-placeholder"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
    />
  </view>

  <!-- 标签筛选 -->
  <scroll-view class="ios-tags-scroll" scroll-x show-scrollbar="{{false}}">
    <view class="ios-tags-container">
      <view
        wx:for="{{tags}}"
        wx:key="index"
        class="ios-tag {{selectedTag === item ? 'ios-tag-active' : ''}}"
        data-tag="{{item}}"
        bindtap="onTagSelect"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <!-- 瀑布流图片列表 -->
  <view class="ios-waterfall" wx:if="{{columnItems[0] && columnItems[0].length > 0}}">
    <view class="ios-waterfall-column" wx:for="{{columnItems}}" wx:key="index" wx:for-item="column" wx:for-index="columnIndex">
      <view
        class="ios-image-card"
        wx:for="{{column}}"
        wx:key="id"
        wx:for-item="item"
        wx:for-index="index"
        bindtap="onViewPicture"
        data-index="{{index}}"
        data-column-index="{{columnIndex}}"
      >
        <!-- 图片 -->
        <image
          class="ios-card-image"
          src="{{item.url}}"
          mode="widthFix"
          lazy-load
          bindtap="onPreviewImage"
          data-index="{{index}}"
          data-column-index="{{columnIndex}}"
        />

        <!-- 图片信息 -->
        <view class="ios-card-content">
          <view class="ios-card-title">{{item.name || '未命名'}}</view>

          <view class="ios-card-stats">
            <view class="ios-stat">
              <van-icon name="eye-o" size="14px" color="#8E8E93" />
              <text class="ios-stat-num">{{item.viewCount || 0}}</text>
            </view>
            <view
              class="ios-stat ios-like-btn {{item.isLiked ? 'liked' : ''}}"
              catchtap="onLikePicture"
              data-id="{{item.id}}"
              data-index="{{index}}"
              data-column-index="{{columnIndex}}"
            >
              <van-icon
                name="{{item.isLiked ? 'like' : 'like-o'}}"
                size="14px"
                color="{{item.isLiked ? '#FF3B30' : '#8E8E93'}}"
              />
              <text class="ios-stat-num {{item.isLiked ? 'liked' : ''}}">{{item.likeCount || 0}}</text>
            </view>
          </view>

          <!-- 标签 -->
          <view class="ios-card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
            <text class="ios-tag-small" wx:for="{{item.tags.slice(0, 2)}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="ios-empty" wx:elif="{{!loading}}">
    <van-icon name="photo-o" size="48px" color="#C6C6C8" />
    <text class="ios-empty-text">暂无图片</text>
  </view>

  <!-- 加载状态 -->
  <view class="ios-loading" wx:elif="{{loading}}">
    <van-loading size="24px" color="#007AFF" />
    <text class="ios-loading-text">加载中...</text>
  </view>

  <!-- 加载更多 -->
  <view class="ios-load-more" wx:if="{{columnItems[0] && columnItems[0].length > 0 && !loading}}">
    <view class="ios-load-more-btn" bindtap="onLoadMore" wx:if="{{hasMore}}">
      <van-loading size="16px" color="#007AFF" />
      <text class="ios-load-more-text">加载更多</text>
    </view>
    <view class="ios-no-more" wx:else>
      <view class="ios-no-more-line"></view>
      <text class="ios-no-more-text">已加载全部</text>
      <view class="ios-no-more-line"></view>
    </view>
  </view>

  <!-- 底部导航 -->
  <bottom-tab active="{{activeTab}}" />
</view>