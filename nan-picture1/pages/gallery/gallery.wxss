/* iOS风格图库页面 */

.gallery-page-ios {
  background-color: #F2F2F7;
  min-height: 100vh;
  padding-bottom: 100px;
}

/* 导航栏大标题 */
.ios-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 96px;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 0.5px solid #C6C6C8;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  padding-top: env(safe-area-inset-top);
}

.ios-nav-title-large {
  font-size: 34px;
  font-weight: 700;
  color: #1C1C1E;
  padding: 12px 16px 0;
}

/* 搜索栏 */
.ios-search-bar {
  position: fixed;
  top: 96px;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 8px 16px 12px;
}

.ios-search-icon {
  margin-right: 6px;
}

.ios-search-input {
  flex: 1;
  font-size: 17px;
  color: #1C1C1E;
  background: transparent;
}

.ios-search-input-placeholder {
  color: #8E8E93;
}

/* 标签筛选 */
.ios-tags-scroll {
  position: fixed;
  top: 152px;
  left: 0;
  right: 0;
  z-index: 998;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  white-space: nowrap;
  padding: 8px 16px;
  border-bottom: 0.5px solid #C6C6C8;
}

.ios-tags-container {
  display: inline-flex;
  gap: 8px;
}

.ios-tag {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 500;
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
  transition: all 0.2s ease;
}

.ios-tag-active {
  background: #007AFF;
  color: #FFFFFF;
}

/* 瀑布流布局 */
.ios-waterfall {
  display: flex;
  gap: 12px;
  padding: 208px 12px 16px;
  width: 100%;
  box-sizing: border-box;
}

.ios-waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-width: 0;
}

/* 图片卡片 */
.ios-image-card {
  background: #FFFFFF;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease;
}

.ios-image-card:active {
  transform: scale(0.98);
}

.ios-card-image {
  width: 100%;
  min-height: 120px;
  background: #F2F2F7;
}

.ios-card-content {
  padding: 12px;
}

.ios-card-title {
  font-size: 15px;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计信息 */
.ios-card-stats {
  display: flex;
  align-items: center;
  gap: 16px;
}

.ios-stat {
  display: flex;
  align-items: center;
  gap: 4px;
}

.ios-stat-num {
  font-size: 13px;
  color: #8E8E93;
}

.ios-stat-num.liked {
  color: #FF3B30;
}

.ios-like-btn {
  transition: transform 0.2s ease;
}

.ios-like-btn:active {
  transform: scale(0.9);
}

.ios-like-btn.liked {
  animation: iosLikeHeart 0.5s ease;
}

/* 卡片标签 */
.ios-card-tags {
  display: flex;
  gap: 6px;
  margin-top: 8px;
  flex-wrap: wrap;
}

.ios-tag-small {
  font-size: 11px;
  padding: 2px 6px;
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
  border-radius: 4px;
}

/* 空状态 */
.ios-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 20px 60px;
}

.ios-empty-icon {
  font-size: 48px;
  color: #C6C6C8;
}

.ios-empty-text {
  font-size: 17px;
  color: #8E8E93;
  margin-top: 12px;
}

/* 加载状态 */
.ios-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.ios-loading-text {
  font-size: 15px;
  color: #8E8E93;
  margin-top: 8px;
}

/* 加载更多 */
.ios-load-more {
  padding: 16px 20px 20px;
  text-align: center;
}

.ios-load-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px;
}

.ios-load-more-text {
  font-size: 15px;
  color: #007AFF;
}

.ios-no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 8px 0;
}

.ios-no-more-line {
  flex: 1;
  height: 0.5px;
  background: #C6C6C8;
  max-width: 80px;
}

.ios-no-more-text {
  font-size: 13px;
  color: #8E8E93;
}