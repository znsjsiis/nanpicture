/* Gallery Page Styles */

.gallery-page {
  background-color: #f5f5f5;
  padding-bottom: 60px;
}

/* Navigation Bar */
.custom-nav-bar {
  height: 44px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid #eee;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

/* Search Section */
.search-section {
  margin: 12px;
  padding: 16px;
  background: #fff;
  border-radius: 12px;
}

.search-box {
  background: #f8f9fa;
  border-radius: 20px;
  padding: 0 16px;
}

/* Tags Section */
.tags-section {
  white-space: nowrap;
  padding: 0 12px 12px;
  background: #fff;
  margin-bottom: 8px;
}

.tags-container {
  display: inline-flex;
  gap: 12px;
  padding: 8px 0;
}

/* Waterfall Layout */
.waterfall-container {
  display: flex;
  gap: 12px;
  padding: 0 12px;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
  box-sizing: border-box;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-width: 0;
}

/* Picture Item */
.picture-item {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.image-wrapper {
  position: relative;
  width: 100%;
}

.picture-info {
  padding: 12px;
}

.picture-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 8px;
}

/* Stats Container */
.stats-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 12px 0;
  padding: 8px 16px;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 12px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 60px;
}

.stat-number {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.stat-label {
  font-size: 12px;
  color: #666;
  margin-top: 2px;
}

.stat-divider {
  width: 1px;
  height: 30px;
  background: #ddd;
  margin: 0 12px;
}

/* Date Info */
.date-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
}

.date-text {
  font-size: 12px;
  color: #999;
  margin-left: 4px;
}

/* Picture Tags */
.picture-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}

.picture-tags .van-tag {
  margin: 2px;
}

/* Like Button */
.like-btn {
  transition: transform 0.2s ease;
}

.like-btn:active {
  transform: scale(0.9);
}

.like-btn.liked {
  animation: likeAnimation 0.3s ease;
}

@keyframes likeAnimation {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
  100% {
    transform: scale(1);
  }
}

/* Empty & Loading States */
.empty-section,
.loading-section {
  padding: 40px 20px;
  text-align: center;
}