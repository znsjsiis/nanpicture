<view class="login-page">
  <!-- 页面背景装饰 -->
  <view class="background-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
    <view class="decoration-circle circle-3"></view>
  </view>
  
  <scroll-view class="page-content" scroll-y>
    <!-- Logo区域 -->
    <view class="logo-section">
      <view class="logo-placeholder">
        <van-icon name="photo" size="80px" color="#ffffff" />
      </view>
      <view class="app-name">小张云图库</view>
      <view class="app-slogan">记录美好瞬间</view>
    </view>
    
    <!-- 登录表单 -->
    <view class="form-section">
      <van-cell-group inset>
  
        
        <!-- 用户名输入 -->
        <van-field
          value="{{formData.userAccount}}"
          label="用户名"
          placeholder="4-20位字母数字下划线"
          border="{{true}}"
          clearable
          maxlength="20"
          data-field="userAccount"
          bind:input="onInputChange"
        />
        <view class="error-message" wx:if="{{errors.userAccount}}">
          <van-icon name="warning-o" size="14px" color="#ff4d4f" />
          <text>{{errors.userAccount}}</text>
        </view>
        
        <!-- 密码输入 -->
        <van-field
          value="{{formData.userPassword}}"
          label="密码"
          placeholder="6-20位密码"
          border="{{true}}"
          type="{{showPassword ? 'text' : 'password'}}"
          maxlength="20"
          data-field="userPassword"
          bind:input="onInputChange"
          right-icon="{{showPassword ? 'eye' : 'closed-eye'}}"
          bind:click-right-icon="onTogglePassword"
          data-toggle-field="userPassword"
        />
        <view class="error-message" wx:if="{{errors.userPassword}}">
          <van-icon name="warning-o" size="14px" color="#ff4d4f" />
          <text>{{errors.userPassword}}</text>
        </view>
      </van-cell-group>
      
      <!-- 忘记密码 -->
      <view class="forgot-password" bindtap="onForgotPassword">
        <text>忘记密码？</text>
      </view>
      
      <!-- 登录按钮 -->
      <view class="button-section">
        <van-button
          type="primary"
          block
          round
          loading="{{loading}}"
          disabled="{{loading}}"
          bindtap="onSubmit"
        >
          {{loading ? '登录中...' : '登录'}}
        </van-button>
      </view>
      
      <!-- 注册入口 -->
      <view class="register-section">
        <text>还没有账号？</text>
        <text class="register-link" bindtap="onGoToRegister">立即注册</text>
      </view>
    </view>
    
    <!-- 第三方登录（占位） -->
    <view class="third-party-section">
      <van-divider>其他登录方式</van-divider>
      <view class="third-party-buttons">
        <van-button
          class="third-party-btn"
          icon="wechat"
          plain
          hairline
          disabled
        >
          微信登录
        </van-button>
        <van-button
          class="third-party-btn"
          icon="qq"
          plain
          hairline
          disabled
        >
          QQ登录
        </van-button>
      </view>
    </view>
  </scroll-view>
</view>